@model PetHealthManagement.Web.ViewModels.Visits.VisitEditViewModel
@{
    ViewData["Title"] = "通院編集";
}

<div class="page-heading">
    <div>
        <h1>通院編集</h1>
        <p class="text-muted">@Model.PetName の通院内容を更新します。</p>
    </div>
</div>

<form asp-action="Edit"
      asp-route-visitId="@Model.VisitId"
      method="post"
      enctype="multipart/form-data"
      class="d-flex flex-column gap-3">
    <partial name="_VisitForm" model="Model" />
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
