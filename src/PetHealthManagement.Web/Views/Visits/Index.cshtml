@model PetHealthManagement.Web.ViewModels.Visits.VisitIndexViewModel
@{
    ViewData["Title"] = "通院";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="page-heading">
    <div>
        <h1>@Model.PetName の通院</h1>
        <p class="text-muted">新しい通院日から並んでいます。</p>
    </div>
    <div class="action-row">
        <a class="btn btn-primary"
           asp-action="Create"
           asp-route-petId="@Model.PetId"
           asp-route-returnUrl="@currentUrl">
            通院を記録
        </a>
        <a class="btn btn-outline-secondary"
           asp-controller="Pets"
           asp-action="Details"
           asp-route-petId="@Model.PetId"
           asp-route-returnUrl="/Pets">
            ペット詳細
        </a>
    </div>
</div>

<p class="text-muted">全 @Model.TotalCount 件 / @Model.Page ページ目</p>

@if (Model.Visits.Count == 0)
{
    <div class="surface">まだ通院履歴は登録されていません。</div>
}
else
{
    <div class="record-list">
        @foreach (var visit in Model.Visits)
        {
            <article class="record-card">
                <div>
                    <p class="record-card__title">@visit.VisitDate.ToString("yyyy/MM/dd")</p>
                    @if (visit.HasImages)
                    {
                        <span class="chip">画像あり</span>
                    }
                </div>

                <dl class="detail-grid record-grid">
                    <div>
                        <dt>病院名</dt>
                        <dd>@(string.IsNullOrWhiteSpace(visit.ClinicName) ? "-" : visit.ClinicName)</dd>
                    </div>
                    <div>
                        <dt>診断</dt>
                        <dd>@(string.IsNullOrWhiteSpace(visit.DiagnosisExcerpt) ? "-" : visit.DiagnosisExcerpt)</dd>
                    </div>
                    <div>
                        <dt>処方</dt>
                        <dd>@(string.IsNullOrWhiteSpace(visit.PrescriptionExcerpt) ? "-" : visit.PrescriptionExcerpt)</dd>
                    </div>
                    <div>
                        <dt>メモ</dt>
                        <dd>@(string.IsNullOrWhiteSpace(visit.NoteExcerpt) ? "-" : visit.NoteExcerpt)</dd>
                    </div>
                </dl>

                <div class="action-row">
                    <a asp-action="Details"
                       asp-route-visitId="@visit.VisitId"
                       asp-route-returnUrl="@currentUrl"
                       class="btn btn-sm btn-outline-primary">
                        詳細
                    </a>
                    <a asp-action="Edit"
                       asp-route-visitId="@visit.VisitId"
                       asp-route-returnUrl="@currentUrl"
                       class="btn btn-sm btn-outline-secondary">
                        編集
                    </a>
                    <form asp-action="Delete"
                          asp-route-visitId="@visit.VisitId"
                          method="post"
                          onsubmit="return confirm('この通院履歴を削除しますか？');">
                        <input type="hidden" name="petId" value="@Model.PetId" />
                        <input type="hidden" name="page" value="@Model.Page" />
                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">削除</button>
                    </form>
                </div>
            </article>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="通院履歴一覧ページャー" class="mt-4">
        <ul class="pagination mb-0">
            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                if (pageNumber == Model.Page)
                {
                    <li class="page-item active"><span class="page-link">@pageNumber</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-petId="@Model.PetId"
                           asp-route-page="@pageNumber">
                            @pageNumber
                        </a>
                    </li>
                }
            }
        </ul>
    </nav>
}
