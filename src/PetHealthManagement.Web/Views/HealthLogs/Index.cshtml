@model PetHealthManagement.Web.ViewModels.HealthLogs.HealthLogIndexViewModel
@{
    ViewData["Title"] = "健康ログ";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="page-heading">
    <div>
        <h1>@Model.PetName の健康ログ</h1>
        <p class="text-muted">新しい記録から並んでいます。</p>
    </div>
    <div class="action-row">
        <a class="btn btn-primary"
           asp-action="Create"
           asp-route-petId="@Model.PetId"
           asp-route-returnUrl="@currentUrl">
            記録する
        </a>
        <a class="btn btn-outline-secondary"
           asp-controller="Pets"
           asp-action="Details"
           asp-route-petId="@Model.PetId"
           asp-route-returnUrl="/Pets">
            ペット詳細
        </a>
    </div>
</div>

<p class="text-muted">全 @Model.TotalCount 件 / @Model.Page ページ目</p>

@if (Model.HealthLogs.Count == 0)
{
    <div class="surface">まだ健康ログが登録されていません。</div>
}
else
{
    <div class="record-list">
        @foreach (var healthLog in Model.HealthLogs)
        {
            <article class="record-card">
                <div>
                    <p class="record-card__title">@healthLog.RecordedAt.ToString("yyyy/MM/dd HH:mm")</p>
                    @if (healthLog.HasImages)
                    {
                        <span class="chip">画像あり</span>
                    }
                </div>

                <dl class="detail-grid record-grid">
                    <div>
                        <dt>体重</dt>
                        <dd>@(healthLog.WeightKg.HasValue ? $"{healthLog.WeightKg.Value:0.0} kg" : "-")</dd>
                    </div>
                    <div>
                        <dt>食事量</dt>
                        <dd>@(healthLog.FoodAmountGram.HasValue ? $"{healthLog.FoodAmountGram.Value} g" : "-")</dd>
                    </div>
                    <div>
                        <dt>散歩時間</dt>
                        <dd>@(healthLog.WalkMinutes.HasValue ? $"{healthLog.WalkMinutes.Value} 分" : "-")</dd>
                    </div>
                    <div>
                        <dt>便の様子</dt>
                        <dd>@(string.IsNullOrWhiteSpace(healthLog.StoolCondition) ? "-" : healthLog.StoolCondition)</dd>
                    </div>
                    <div>
                        <dt>メモ</dt>
                        <dd>@(string.IsNullOrWhiteSpace(healthLog.NoteExcerpt) ? "-" : healthLog.NoteExcerpt)</dd>
                    </div>
                </dl>

                <div class="action-row">
                    <a asp-action="Details"
                       asp-route-healthLogId="@healthLog.HealthLogId"
                       asp-route-returnUrl="@currentUrl"
                       class="btn btn-sm btn-outline-primary">
                        詳細
                    </a>
                    <a asp-action="Edit"
                       asp-route-healthLogId="@healthLog.HealthLogId"
                       asp-route-returnUrl="@currentUrl"
                       class="btn btn-sm btn-outline-secondary">
                        編集
                    </a>
                    <form asp-action="Delete"
                          asp-route-healthLogId="@healthLog.HealthLogId"
                          method="post">
                        <input type="hidden" name="petId" value="@Model.PetId" />
                        <input type="hidden" name="page" value="@Model.Page" />
                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">削除</button>
                    </form>
                </div>
            </article>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="健康ログ一覧ページャー" class="mt-4">
        <ul class="pagination mb-0">
            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                if (pageNumber == Model.Page)
                {
                    <li class="page-item active"><span class="page-link">@pageNumber</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-petId="@Model.PetId"
                           asp-route-page="@pageNumber">
                            @pageNumber
                        </a>
                    </li>
                }
            }
        </ul>
    </nav>
}
