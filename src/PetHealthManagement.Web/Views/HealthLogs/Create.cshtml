@model PetHealthManagement.Web.ViewModels.HealthLogs.HealthLogEditViewModel
@{
    ViewData["Title"] = "健康ログ作成";
}

<div class="page-heading">
    <div>
        <h1>健康ログ作成</h1>
        <p class="text-muted">@Model.PetName の体調を記録します。</p>
    </div>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-3">
    <partial name="_HealthLogForm" model="Model" />
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
