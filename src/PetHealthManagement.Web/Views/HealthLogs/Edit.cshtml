@model PetHealthManagement.Web.ViewModels.HealthLogs.HealthLogEditViewModel
@{
    ViewData["Title"] = "健康ログ編集";
}

<div class="page-heading">
    <div>
        <h1>健康ログ編集</h1>
        <p class="text-muted">@Model.PetName の記録を更新します。</p>
    </div>
</div>

<form asp-action="Edit"
      asp-route-healthLogId="@Model.HealthLogId"
      method="post"
      enctype="multipart/form-data"
      class="d-flex flex-column gap-3">
    <partial name="_HealthLogForm" model="Model" />
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
