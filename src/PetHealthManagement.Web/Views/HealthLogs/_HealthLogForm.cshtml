@model PetHealthManagement.Web.ViewModels.HealthLogs.HealthLogEditViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
<input type="hidden" asp-for="PetId" />
<input type="hidden" asp-for="RowVersion" />

<div class="card shadow-sm">
    <div class="card-body d-flex flex-column gap-3">
        <div>
            <h2 class="h5 mb-1">@Model.PetName</h2>
            <p class="text-muted mb-0">健康ログは記録日時を JST で保存します。</p>
        </div>

        <div>
            <label asp-for="RecordedAt" class="form-label">記録日時</label>
            <input asp-for="RecordedAt"
                   type="datetime-local"
                   class="form-control"
                   asp-format="{0:yyyy-MM-ddTHH:mm}" />
            <span asp-validation-for="RecordedAt" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="WeightKg" class="form-label">体重(kg)</label>
                <input asp-for="WeightKg" class="form-control" />
                <span asp-validation-for="WeightKg" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="FoodAmountGram" class="form-label">食事量(g)</label>
                <input asp-for="FoodAmountGram" class="form-control" />
                <span asp-validation-for="FoodAmountGram" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="WalkMinutes" class="form-label">散歩時間(分)</label>
                <input asp-for="WalkMinutes" class="form-control" />
                <span asp-validation-for="WalkMinutes" class="text-danger"></span>
            </div>
        </div>

        <div>
            <label asp-for="StoolCondition" class="form-label">便の様子</label>
            <input asp-for="StoolCondition" class="form-control" />
            <span asp-validation-for="StoolCondition" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Note" class="form-label">メモ</label>
            <textarea asp-for="Note" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>
    </div>
</div>

@if (Model.ExistingImages.Count > 0)
{
    <section class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5">登録済み画像</h2>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var image in Model.ExistingImages)
                {
                    <label class="border rounded p-2 d-flex flex-column gap-2" style="width: 180px;">
                        <img src="@image.Url"
                             alt="@image.AltText"
                             style="width: 100%; height: 140px; object-fit: cover;" />
                        <span class="form-check mb-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="DeleteImageIds"
                                   value="@image.ImageId"
                                   @(Model.DeleteImageIds.Contains(image.ImageId) ? "checked" : null) />
                            <span class="form-check-label">削除する</span>
                        </span>
                    </label>
                }
            </div>
        </div>
    </section>
}

<section class="card shadow-sm">
    <div class="card-body">
        <h2 class="h5">画像追加</h2>
        <input asp-for="NewFiles"
               type="file"
               class="form-control"
               multiple
               accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
        <div class="form-text">jpg / jpeg / png / webp、1枚 2MB まで、健康ログ1件あたり合計10枚まで登録できます。</div>
        <span asp-validation-for="NewFiles" class="text-danger"></span>
    </div>
</section>

<div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">保存</button>
    <a href="@Model.CancelUrl" class="btn btn-outline-secondary">キャンセル</a>
</div>
