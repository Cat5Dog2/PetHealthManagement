@model PetHealthManagement.Web.ViewModels.Account.DeleteAccountViewModel
@{
    ViewData["Title"] = "アカウント削除";
}

<div class="d-flex flex-column gap-3">
    <h1>アカウント削除</h1>

    <div class="alert alert-danger mb-0">
        <p class="mb-2">この操作を実行すると、アカウントと関連データが物理削除されます。</p>
        <ul class="mb-0">
            <li>プロフィール情報</li>
            <li>登録済みのペット</li>
            <li>アップロード済みの画像</li>
            <li>今後追加される関連データも復元できません</li>
        </ul>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">表示名</dt>
                <dd class="col-sm-9">@Model.DisplayName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
            </dl>
        </div>
    </div>

    <form asp-action="DeleteConfirmed" method="post" class="d-flex gap-2">
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="btn btn-danger">削除する</button>
        <a href="@Model.CancelUrl" class="btn btn-outline-secondary">キャンセル</a>
    </form>
</div>
