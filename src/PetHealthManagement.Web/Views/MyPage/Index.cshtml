@model PetHealthManagement.Web.ViewModels.MyPage.MyPageViewModel
@{
    ViewData["Title"] = "ホーム";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="d-flex flex-column gap-4">
    <section class="profile-panel">
        <div class="d-flex flex-column flex-sm-row gap-3 align-items-start align-items-sm-center">
            <img src="@Model.AvatarUrl" alt="プロフィール画像" class="mypage-avatar" />
            <div class="flex-grow-1">
                <p class="text-muted mb-1">ホーム</p>
                <h1 class="h3 mb-2">@Model.DisplayName</h1>
                <p class="mb-0">@Model.Email</p>
            </div>
        </div>

        <div class="action-row mt-4">
            <a asp-controller="Account"
               asp-action="EditProfile"
               asp-route-returnUrl="@currentUrl"
               class="btn btn-primary">
                プロフィール編集
            </a>
            <a href="/Identity/Account/Manage/ChangePassword"
               class="btn btn-outline-primary">
                パスワード変更
            </a>
            <a asp-controller="Account"
               asp-action="Delete"
               asp-route-returnUrl="@currentUrl"
               class="btn btn-outline-danger">
                アカウント削除
            </a>
        </div>
    </section>

    <section>
        <div class="page-heading">
            <div>
                <h1>うちの子</h1>
                <p class="text-muted">登録したペットの記録へ進めます。</p>
            </div>
            <a asp-controller="Pets"
               asp-action="Create"
               asp-route-returnUrl="@currentUrl"
               class="btn btn-primary">
                ペット登録
            </a>
        </div>

        @if (Model.Pets.Count == 0)
        {
            <div class="surface">
                <p class="mb-3">ペットがまだ登録されていません。</p>
                <a asp-controller="Pets"
                   asp-action="Create"
                   asp-route-returnUrl="@currentUrl"
                   class="btn btn-primary">
                    最初のペットを登録
                </a>
            </div>
        }
        else
        {
            <div class="pet-list">
                @foreach (var pet in Model.Pets)
                {
                    <article class="pet-card">
                        <img src="@pet.PhotoUrl" alt="@pet.Name の写真" class="pet-photo pet-card__photo" />
                        <div class="pet-card__body">
                            <div class="pet-card__title">
                                <h2>@pet.Name</h2>
                                @if (pet.IsPublic)
                                {
                                    <span class="chip">公開</span>
                                }
                                else
                                {
                                    <span class="chip chip-muted">非公開</span>
                                }
                            </div>
                            <p class="text-muted mb-0">@pet.SpeciesLabel</p>
                            <div class="action-row">
                                <a asp-controller="Pets"
                                   asp-action="Details"
                                   asp-route-petId="@pet.PetId"
                                   asp-route-returnUrl="@currentUrl"
                                   class="btn btn-sm btn-outline-primary">
                                    詳細
                                </a>
                                <a href="/HealthLogs?petId=@pet.PetId" class="btn btn-sm btn-outline-secondary">健康ログ</a>
                                <a href="/ScheduleItems?petId=@pet.PetId" class="btn btn-sm btn-outline-secondary">予定</a>
                                <a href="/Visits?petId=@pet.PetId" class="btn btn-sm btn-outline-secondary">通院</a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>
