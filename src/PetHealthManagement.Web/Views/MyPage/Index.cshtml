@model PetHealthManagement.Web.ViewModels.MyPage.MyPageViewModel
@{
    ViewData["Title"] = "MyPage";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="d-flex flex-column gap-4">
    <section class="card shadow-sm">
        <div class="card-body">
            <div class="row g-4 align-items-center">
                <div class="col-md-auto">
                    <img src="@Model.AvatarUrl" alt="プロフィール画像" class="mypage-avatar" />
                </div>
                <div class="col">
                    <h1 class="h3 mb-3">MyPage</h1>
                    <dl class="row mb-0">
                        <dt class="col-sm-3">表示名</dt>
                        <dd class="col-sm-9">@Model.DisplayName</dd>

                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Model.Email</dd>
                    </dl>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <a asp-controller="Account"
                   asp-action="EditProfile"
                   asp-route-returnUrl="@currentUrl"
                   class="btn btn-primary">
                    プロフィール編集
                </a>
                <a asp-area="Identity"
                   asp-page="/Account/Manage/ChangePassword"
                   class="btn btn-outline-primary">
                    パスワード変更
                </a>
                <a asp-controller="Account"
                   asp-action="Delete"
                   asp-route-returnUrl="@currentUrl"
                   class="btn btn-outline-danger">
                    アカウント削除
                </a>
                <a asp-controller="Pets"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    ペット一覧へ
                </a>
            </div>
        </div>
    </section>

    <section class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div>
                    <h2 class="h4 mb-1">自分のペット</h2>
                    <p class="text-muted mb-0">登録済みのペットから、詳細や記録画面へ進めます。</p>
                </div>
                <a asp-controller="Pets"
                   asp-action="Create"
                   asp-route-returnUrl="@currentUrl"
                   class="btn btn-primary">
                    ＋ ペット登録
                </a>
            </div>

            @if (Model.Pets.Count == 0)
            {
                <div class="alert alert-secondary mb-0">
                    ペットがまだ登録されていません。最初の1匹を登録してください。
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var pet in Model.Pets)
                    {
                        <div class="col-md-6 col-xl-4">
                            <article class="card h-100 border-0 bg-light-subtle">
                                <div class="card-body d-flex flex-column gap-3">
                                    <img src="@pet.PhotoUrl" alt="@pet.Name の写真" class="mypage-pet-photo" />
                                    <div>
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                            <h3 class="h5 mb-0">@pet.Name</h3>
                                            @if (pet.IsPublic)
                                            {
                                                <span class="badge text-bg-success">公開</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary">非公開</span>
                                            }
                                        </div>
                                        <p class="text-muted mb-0">@pet.SpeciesLabel</p>
                                    </div>
                                    <div class="mt-auto d-flex flex-wrap gap-2">
                                        <a asp-controller="Pets"
                                           asp-action="Details"
                                           asp-route-petId="@pet.PetId"
                                           asp-route-returnUrl="@currentUrl"
                                           class="btn btn-sm btn-outline-primary">
                                            詳細
                                        </a>
                                        <a href="/HealthLogs?petId=@pet.PetId" class="btn btn-sm btn-outline-secondary">健康ログ</a>
                                        <a href="/ScheduleItems?petId=@pet.PetId" class="btn btn-sm btn-outline-secondary">予定</a>
                                        <a href="/Visits?petId=@pet.PetId" class="btn btn-sm btn-outline-secondary">通院履歴</a>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</div>
