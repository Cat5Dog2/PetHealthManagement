@model PetHealthManagement.Web.ViewModels.ScheduleItems.ScheduleItemEditViewModel
@{
    ViewData["Title"] = "予定作成";
}

<div class="page-heading">
    <div>
        <h1>予定作成</h1>
        <p class="text-muted">@Model.PetName の予定を登録します。</p>
    </div>
</div>

<form asp-action="Create" method="post" class="d-flex flex-column gap-3">
    <partial name="_ScheduleItemForm" model="Model" />
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
