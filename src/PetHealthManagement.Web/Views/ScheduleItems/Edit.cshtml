@model PetHealthManagement.Web.ViewModels.ScheduleItems.ScheduleItemEditViewModel
@{
    ViewData["Title"] = "予定編集";
}

<div class="page-heading">
    <div>
        <h1>予定編集</h1>
        <p class="text-muted">@Model.PetName の予定を更新します。</p>
    </div>
</div>

<form asp-action="Edit"
      asp-route-scheduleItemId="@Model.ScheduleItemId"
      method="post"
      class="d-flex flex-column gap-3">
    <partial name="_ScheduleItemForm" model="Model" />
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
