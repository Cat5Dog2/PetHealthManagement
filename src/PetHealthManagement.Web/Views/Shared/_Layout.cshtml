<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2f9e9b" />
    <title>@ViewData["Title"] - うちの子健康カルテ</title>
    <script type="importmap"></script>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="~/icons/apple-touch-icon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PetHealthManagement.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"] as string ?? string.Empty;
        var currentArea = ViewContext.RouteData.Values["area"] as string ?? string.Empty;
        var isHomeTab = string.Equals(currentController, "MyPage", StringComparison.OrdinalIgnoreCase);
        var isPetsTab = string.Equals(currentController, "Pets", StringComparison.OrdinalIgnoreCase);
        var isRecordTab = currentController is "HealthLogs" or "ScheduleItems" or "Visits";
        var isSettingsTab = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase)
            || string.Equals(currentArea, "Identity", StringComparison.OrdinalIgnoreCase);
    }
    <header class="app-topbar">
        <nav class="navbar navbar-expand-md navbar-light px-3">
            <div class="container-fluid px-0">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">うちの子健康カルテ</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="mainNavigation"
                        aria-expanded="false" aria-label="メニューを開く">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNavigation" class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="MyPage" asp-action="Index">ホーム</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Pets" asp-action="Index">ペット</a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">Admin</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">トップ</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main">
        <partial name="_StatusAlert" />
        @RenderBody()
    </main>

    <footer class="app-footer">
        &copy; 2026 うちの子健康カルテ
    </footer>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="app-bottom-nav" aria-label="主な操作">
            <a asp-area="" asp-controller="MyPage" asp-action="Index"
               class="@(isHomeTab ? "is-active" : null)" aria-current="@(isHomeTab ? "page" : null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 10.5 12 3l9 7.5" />
                    <path d="M5 9.5V21h5v-6h4v6h5V9.5" />
                </svg>
                <span>ホーム</span>
            </a>
            <a asp-area="" asp-controller="Pets" asp-action="Index"
               class="@(isPetsTab ? "is-active" : null)" aria-current="@(isPetsTab ? "page" : null)">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <ellipse cx="7.2" cy="7.6" rx="2" ry="2.7" />
                    <ellipse cx="16.8" cy="7.6" rx="2" ry="2.7" />
                    <ellipse cx="3.6" cy="12.4" rx="1.8" ry="2.3" />
                    <ellipse cx="20.4" cy="12.4" rx="1.8" ry="2.3" />
                    <path d="M12 11.2c-3.3 0-6 2.6-6 5.4 0 2 1.5 3.4 3.5 3.4 1 0 1.7-.4 2.5-.4s1.5.4 2.5.4c2 0 3.5-1.4 3.5-3.4 0-2.8-2.7-5.4-6-5.4z" />
                </svg>
                <span>ペット</span>
            </a>
            <a asp-area="" asp-controller="HealthLogs" asp-action="Record"
               class="@(isRecordTab ? "is-active" : null)" aria-current="@(isRecordTab ? "page" : null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 8v8M8 12h8" />
                </svg>
                <span>記録</span>
            </a>
            <a asp-area="" asp-controller="Account" asp-action="EditProfile" asp-route-returnUrl="/MyPage"
               class="@(isSettingsTab ? "is-active" : null)" aria-current="@(isSettingsTab ? "page" : null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 7h8M18 7h2M4 12h2M12 12h8M4 17h10M20 17h0" />
                    <circle cx="15" cy="7" r="2" />
                    <circle cx="9" cy="12" r="2" />
                    <circle cx="17" cy="17" r="2" />
                </svg>
                <span>設定</span>
            </a>
        </nav>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
