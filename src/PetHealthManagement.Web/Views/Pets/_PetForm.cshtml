@model PetHealthManagement.Web.ViewModels.Pets.PetEditViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
<input type="hidden" asp-for="RowVersion" />

@if (!string.IsNullOrWhiteSpace(Model.CurrentPhotoUrl))
{
    <div class="mb-3">
        <label class="form-label">現在の写真</label>
        <div>
            <img src="@Model.CurrentPhotoUrl" alt="現在のペット写真" class="pet-photo" style="max-width: 240px;" />
        </div>
    </div>
}

<div class="mb-3">
    <label asp-for="Name" class="form-label">名前</label>
    <input asp-for="Name"
           class="form-control"
           maxlength="@PetHealthManagement.Web.Infrastructure.InputValidationLimits.Pets.NameMaxLength" />
    <span asp-validation-for="Name" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="SpeciesCode" class="form-label">種別</label>
    <select asp-for="SpeciesCode" class="form-select">
        <option value="">選択してください</option>
        @foreach (var option in Model.SpeciesOptions)
        {
            <option value="@option.Code">@option.Label</option>
        }
    </select>
    <span asp-validation-for="SpeciesCode" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Breed" class="form-label">品種</label>
    <input asp-for="Breed"
           class="form-control"
           maxlength="@PetHealthManagement.Web.Infrastructure.InputValidationLimits.Pets.BreedMaxLength" />
    <span asp-validation-for="Breed" class="text-danger"></span>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <label asp-for="Sex" class="form-label">性別</label>
        <input asp-for="Sex"
               class="form-control"
               list="pet-sex-options"
               maxlength="@PetHealthManagement.Web.Infrastructure.InputValidationLimits.Pets.SexMaxLength" />
        <datalist id="pet-sex-options">
            <option value="オス"></option>
            <option value="メス"></option>
            <option value="不明"></option>
        </datalist>
        <span asp-validation-for="Sex" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="BirthDate" class="form-label">誕生日</label>
        <input asp-for="BirthDate"
               type="date"
               class="form-control"
               asp-format="{0:yyyy-MM-dd}" />
        <span asp-validation-for="BirthDate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="AdoptedDate" class="form-label">迎えた日</label>
        <input asp-for="AdoptedDate"
               type="date"
               class="form-control"
               asp-format="{0:yyyy-MM-dd}" />
        <span asp-validation-for="AdoptedDate" class="text-danger"></span>
    </div>
</div>

<div class="form-check mb-3">
    <input asp-for="IsPublic" class="form-check-input" />
    <label asp-for="IsPublic" class="form-check-label">公開する</label>
</div>

<div class="mb-3">
    <label asp-for="PhotoFile" class="form-label">写真（jpg / jpeg / png / webp、2MB以下）</label>
    <input asp-for="PhotoFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
    <span asp-validation-for="PhotoFile" class="text-danger"></span>
</div>

@if (!string.IsNullOrWhiteSpace(Model.CurrentPhotoUrl))
{
    <div class="form-check mb-3">
        <input asp-for="RemovePhoto" class="form-check-input" />
        <label asp-for="RemovePhoto" class="form-check-label">現在の写真を削除する</label>
    </div>
}

<div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">保存</button>
    <a href="@Model.CancelUrl" class="btn btn-outline-secondary">キャンセル</a>
</div>
