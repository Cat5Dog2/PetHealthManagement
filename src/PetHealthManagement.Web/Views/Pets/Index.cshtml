@model PetHealthManagement.Web.ViewModels.Pets.PetSearchViewModel
@{
    ViewData["Title"] = "ペット";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="page-heading">
    <div>
        <h1>ペット</h1>
        <p class="text-muted">公開中の子と、自分の子を探せます。</p>
    </div>
    <a asp-action="Create" asp-route-returnUrl="@currentUrl" class="btn btn-primary">ペット登録</a>
</div>

<form asp-action="Index" method="get" class="surface mb-4">
    <div class="row g-3">
        <div class="col-md-5">
            <label for="nameKeyword" class="form-label">名前</label>
            <input id="nameKeyword" name="nameKeyword" value="@Model.NameKeyword" class="form-control" />
        </div>
        <div class="col-md-5">
            <label for="speciesFilter" class="form-label">種別</label>
            <select id="speciesFilter" name="speciesFilter" class="form-select">
                <option value="">すべて</option>
                @foreach (var option in Model.SpeciesOptions)
                {
                    if (string.Equals(option.Code, Model.SpeciesFilter, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option.Code" selected>@option.Label</option>
                    }
                    else
                    {
                        <option value="@option.Code">@option.Label</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2 d-grid align-self-end">
            <button type="submit" class="btn btn-primary">検索</button>
        </div>
    </div>
</form>

<p class="text-muted">全 @Model.TotalCount 件 / @Model.Page ページ目</p>

@if (Model.Pets.Count == 0)
{
    <div class="surface">該当するペットがありません。</div>
}
else
{
    <div class="pet-list">
        @foreach (var pet in Model.Pets)
        {
            <article class="pet-card">
                <img src="@pet.PhotoUrl" alt="@pet.Name の写真" class="pet-photo pet-card__photo" />
                <div class="pet-card__body">
                    <div class="pet-card__title">
                        <h2>@pet.Name</h2>
                        @if (pet.IsOwner)
                        {
                            <span class="chip chip-warm">うちの子</span>
                        }
                        else
                        {
                            <span class="chip">公開</span>
                        }
                    </div>
                    <dl class="detail-grid">
                        <div>
                            <dt>種別</dt>
                            <dd>@pet.SpeciesLabel</dd>
                        </div>
                        <div>
                            <dt>品種</dt>
                            <dd>@(string.IsNullOrWhiteSpace(pet.Breed) ? "-" : pet.Breed)</dd>
                        </div>
                        <div>
                            <dt>オーナー</dt>
                            <dd>@pet.OwnerDisplayName</dd>
                        </div>
                        <div>
                            <dt>公開設定</dt>
                            <dd>@(pet.IsOwner ? (pet.IsPublic ? "公開" : "非公開") : "公開")</dd>
                        </div>
                    </dl>
                    <div class="action-row">
                        <a asp-action="Details"
                           asp-route-petId="@pet.PetId"
                           asp-route-returnUrl="@currentUrl"
                           class="btn btn-sm btn-outline-primary">
                            詳細
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="ペット一覧ページャー" class="mt-4">
        <ul class="pagination mb-0">
            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                if (pageNumber == Model.Page)
                {
                    <li class="page-item active"><span class="page-link">@pageNumber</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-nameKeyword="@Model.NameKeyword"
                           asp-route-speciesFilter="@Model.SpeciesFilter"
                           asp-route-page="@pageNumber">
                            @pageNumber
                        </a>
                    </li>
                }
            }
        </ul>
    </nav>
}
