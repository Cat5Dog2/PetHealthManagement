@model PetHealthManagement.Web.ViewModels.Identity.Manage.IdentityManageTwoFactorViewModel
@{
    ViewData["Title"] = "二要素認証";
}

<div class="page-heading">
    <div>
        <h1>アカウント管理</h1>
        <p class="text-muted">二要素認証の状態を確認できます。</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <partial name="_ManageNav" />
    </div>
    <div class="col-md-8">
        <section class="surface">
            <h2 class="h4 mb-3">二要素認証</h2>
            <dl class="detail-grid">
                <div>
                    <dt>状態</dt>
                    <dd>@(Model.IsTwoFactorEnabled ? "有効" : "無効")</dd>
                </div>
                <div>
                    <dt>この端末の記憶</dt>
                    <dd>@(Model.IsMachineRemembered ? "記憶済み" : "未記憶")</dd>
                </div>
                <div>
                    <dt>リカバリーコード</dt>
                    <dd>@Model.RecoveryCodesLeft 件</dd>
                </div>
            </dl>
            <p class="text-muted mt-3 mb-0">二要素認証の設定機能は、今後の拡張対象です。</p>
        </section>
    </div>
</div>
