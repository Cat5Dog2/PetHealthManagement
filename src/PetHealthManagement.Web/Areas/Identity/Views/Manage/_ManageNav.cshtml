@{
    var activeAction = ViewContext.RouteData.Values["action"]?.ToString();

    string NavClass(string action)
    {
        return string.Equals(activeAction, action, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;
    }
}

<nav class="nav nav-pills flex-column gap-2" aria-label="アカウント管理">
    <a class="nav-link @NavClass("Index")" href="/Identity/Account/Manage">プロフィール</a>
    <a class="nav-link @NavClass("Email")" href="/Identity/Account/Manage/Email">メールアドレス</a>
    <a class="nav-link @NavClass("ChangePassword")" href="/Identity/Account/Manage/ChangePassword">パスワード</a>
    <a class="nav-link @NavClass("PersonalData")" href="/Identity/Account/Manage/PersonalData">個人データ</a>
</nav>
