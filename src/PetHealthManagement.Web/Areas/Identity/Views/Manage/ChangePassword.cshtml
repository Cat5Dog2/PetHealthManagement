@model PetHealthManagement.Web.ViewModels.Identity.Manage.IdentityManageChangePasswordViewModel
@{
    ViewData["Title"] = "パスワード";
}

<div class="page-heading">
    <div>
        <h1>アカウント管理</h1>
        <p class="text-muted">パスワードを変更できます。</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <partial name="_ManageNav" />
    </div>
    <div class="col-md-8">
        <section class="form-panel">
            <h2 class="h4 mb-3">パスワード</h2>
            <partial name="_StatusMessage" model="Model.StatusMessage" />

            <form method="post" class="d-flex flex-column gap-3">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div>
                    <label asp-for="OldPassword" class="form-label">現在のパスワード</label>
                    <input asp-for="OldPassword" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="NewPassword" class="form-label">新しいパスワード</label>
                    <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="form-label">新しいパスワード（確認）</label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">パスワードを変更</button>
            </form>
        </section>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
