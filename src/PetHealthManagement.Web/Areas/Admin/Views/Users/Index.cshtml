@model PetHealthManagement.Web.ViewModels.Admin.Users.AdminUserIndexViewModel
@{
    ViewData["Title"] = "Admin Users";
}

<div class="d-flex flex-column gap-3">
    <div>
        <h1 class="mb-1">Admin Users</h1>
        <p class="text-muted mb-0">Deleting a user permanently removes related pets, logs, visits, schedules, and images.</p>
    </div>

    <p class="mb-0">Total @Model.TotalCount users / Page @Model.Page / @Model.PageSize per page</p>

    @if (Model.Users.Count == 0)
    {
        <div class="alert alert-secondary mb-0">
            No users were found for this page.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Display Name</th>
                        <th>Email</th>
                        <th>Pets</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td><code>@user.UserId</code></td>
                            <td>@user.DisplayName</td>
                            <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                            <td>@user.PetCount</td>
                            <td>
                                <form asp-area="Admin"
                                      asp-controller="Users"
                                      asp-action="Delete"
                                      asp-route-userId="@user.UserId"
                                      method="post"
                                      class="d-inline"
                                      data-confirm="Delete this user and all related data?">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @{
        var pagerModel = new ListPagerViewModel
        {
            AriaLabel = "Admin user pagination",
            Page = Model.Page,
            TotalPages = Model.TotalPages,
            PreviousUrl = Model.Page > 1 ? Url.Action("Index", "Users", new { area = "Admin", page = Model.Page - 1 }) : null,
            NextUrl = Model.Page < Model.TotalPages ? Url.Action("Index", "Users", new { area = "Admin", page = Model.Page + 1 }) : null
        };
    }
    <partial name="_ListPager" model="pagerModel" />
</div>
